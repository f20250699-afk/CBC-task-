# LLM Configuration
# Provide your SambaNova, OpenAI, or Anthropic API key here.
LLM_API_KEY="your-api-key-here"

# Leave blank for default OpenAI.
# For SambaNova, set to their base URL (e.g. "https://api.sambanova.ai/v1")
LLM_BASE_URL="https://api.sambanova.ai/v1"

# Specify the model name
LLM_MODEL="Meta-Llama-3.3-70B-Instruct"

# Optional Redis session store (defaults to in-memory dict if not provided)
# REDIS_URL="redis://localhost:6379"
